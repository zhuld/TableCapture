{
  "manifest_version": 3,
  "name": "成绩表提取器",
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "version": "0.1.0",
  "description": "自动识别网页中的成绩表，并导出为 JSON 文件",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "成绩表提取器",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab", 
    "scripting"
  ],
  "host_permissions": [
  "https://example.com/*",
  "http://*/*"
  ]
}